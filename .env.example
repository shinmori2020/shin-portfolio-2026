# 問い合わせフォーム（Resend）用の環境変数
# これらを未設定のままだとフォームは「スタブ動作」で受付（メールは送られない）。
# 本番でメールを届けるには Vercel のプロジェクト設定に以下を登録する。

# Resend のAPIキー（Vercelでは Sensitive: ON 推奨）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 送信元アドレス。独自ドメイン登録前は onboarding@resend.dev を使う
CONTACT_EMAIL_FROM=onboarding@resend.dev
# 独自ドメイン登録後の例: CONTACT_EMAIL_FROM=hello@shin-example.com

# 通知の宛先（＝シンの受信用メール）。独自ドメイン未登録時は Resend 登録アドレスと同じにする
CONTACT_EMAIL_TO=your-name@example.com
