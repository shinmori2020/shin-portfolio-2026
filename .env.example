# 問い合わせフォーム（Resend）用の環境変数
# RESEND_API_KEY が未設定だとフォームは「スタブ動作」で受付（メールは送られない）。
# 本番でメールを届けるには Vercel のプロジェクト設定に以下を登録する。

# Resend のAPIキー（Vercelでは Sensitive: ON 推奨）※必須
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 通知の宛先（＝シンの受信用メール）※必須
# 独自ドメイン未登録の間は Resend アカウントの登録アドレスと同じである必要がある
CONTACT_EMAIL_TO=your-name@example.com

# 送信元アドレス（任意）。未設定なら onboarding@resend.dev で送る。
# 独自ドメインを Resend に登録し SPF/DKIM を通したら、ここを自ドメインのアドレスにする。
# 設定した時点で問い合わせ者への自動返信も自動的に有効になる。
# CONTACT_EMAIL_FROM=シン <hello@your-domain.com>
